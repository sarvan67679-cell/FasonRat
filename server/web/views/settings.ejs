<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Settings</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <a href="/" class="brand"><span class="fs-icon-sm">FS</span> Fason</a>
        <div class="nav-links">
            <a href="/">Dashboard</a>
            <a href="/builder">Builder</a>
            <a href="/logs">Logs</a>
            <a href="/settings" class="active">Settings</a>
            <a href="/logout">Logout</a>
        </div>
    </nav>

    <main class="container">
        <div class="card">
            <h2>Server Settings</h2>
            <p class="subtitle">Configure server limits, security, and other options</p>

            <div class="settings-grid">
                <!-- Server Settings -->
                <div class="settings-section">
                    <h3>🌐 Server</h3>
                    <div class="setting-item">
                        <span class="setting-label">Port</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="port" value="<%= config.port %>" data-key="port">
                            <button class="save-btn" onclick="saveSetting('port')">Save</button>
                            <span class="setting-saved" id="saved-port">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Debug Mode</span>
                        <div class="setting-value">
                            <label class="toggle-switch">
                                <input type="checkbox" id="debug" <%= config.debug ? 'checked' : '' %> onchange="saveSetting('debug', this.checked)">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Limits -->
                <div class="settings-section">
                    <h3>📊 Limits</h3>
                    <div class="setting-item">
                        <span class="setting-label">Max Clients</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="limits.maxClients" value="<%= config.limits.maxClients %>" data-key="limits.maxClients">
                            <button class="save-btn" onclick="saveSetting('limits.maxClients')">Save</button>
                            <span class="setting-saved" id="saved-limits.maxClients">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Max Downloads</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="limits.maxDownloads" value="<%= config.limits.maxDownloads %>" data-key="limits.maxDownloads">
                            <button class="save-btn" onclick="saveSetting('limits.maxDownloads')">Save</button>
                            <span class="setting-saved" id="saved-limits.maxDownloads">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Max Photos</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="limits.maxPhotos" value="<%= config.limits.maxPhotos %>" data-key="limits.maxPhotos">
                            <button class="save-btn" onclick="saveSetting('limits.maxPhotos')">Save</button>
                            <span class="setting-saved" id="saved-limits.maxPhotos">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Max Recordings</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="limits.maxRecordings" value="<%= config.limits.maxRecordings %>" data-key="limits.maxRecordings">
                            <button class="save-btn" onclick="saveSetting('limits.maxRecordings')">Save</button>
                            <span class="setting-saved" id="saved-limits.maxRecordings">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Max GPS History</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="limits.maxGpsHistory" value="<%= config.limits.maxGpsHistory %>" data-key="limits.maxGpsHistory">
                            <button class="save-btn" onclick="saveSetting('limits.maxGpsHistory')">Save</button>
                            <span class="setting-saved" id="saved-limits.maxGpsHistory">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Max SMS History</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="limits.maxSmsHistory" value="<%= config.limits.maxSmsHistory %>" data-key="limits.maxSmsHistory">
                            <button class="save-btn" onclick="saveSetting('limits.maxSmsHistory')">Save</button>
                            <span class="setting-saved" id="saved-limits.maxSmsHistory">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Max Calls History</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="limits.maxCallsHistory" value="<%= config.limits.maxCallsHistory %>" data-key="limits.maxCallsHistory">
                            <button class="save-btn" onclick="saveSetting('limits.maxCallsHistory')">Save</button>
                            <span class="setting-saved" id="saved-limits.maxCallsHistory">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Max Notifications</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="limits.maxNotifications" value="<%= config.limits.maxNotifications %>" data-key="limits.maxNotifications">
                            <button class="save-btn" onclick="saveSetting('limits.maxNotifications')">Save</button>
                            <span class="setting-saved" id="saved-limits.maxNotifications">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Max Clipboard History</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="limits.maxClipboardHistory" value="<%= config.limits.maxClipboardHistory %>" data-key="limits.maxClipboardHistory">
                            <button class="save-btn" onclick="saveSetting('limits.maxClipboardHistory')">Save</button>
                            <span class="setting-saved" id="saved-limits.maxClipboardHistory">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Max File Size (MB)</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="limits.maxFileSize" value="<%= config.limits.maxFileSize / (1024 * 1024) %>" data-key="limits.maxFileSize" data-multiplier="1048576">
                            <button class="save-btn" onclick="saveSetting('limits.maxFileSize', null, 1048576)">Save</button>
                            <span class="setting-saved" id="saved-limits.maxFileSize">✓</span>
                        </div>
                    </div>
                </div>

                <!-- Security -->
                <div class="settings-section">
                    <h3>🔒 Security</h3>
                    <div class="setting-item">
                        <span class="setting-label">Session Timeout (hours)</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="security.sessionTimeout" value="<%= config.security.sessionTimeout / (60 * 60 * 1000) %>" data-key="security.sessionTimeout">
                            <button class="save-btn" onclick="saveSetting('security.sessionTimeout', null, 3600000)">Save</button>
                            <span class="setting-saved" id="saved-security.sessionTimeout">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Max Login Attempts</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="security.loginAttempts" value="<%= config.security.loginAttempts %>" data-key="security.loginAttempts">
                            <button class="save-btn" onclick="saveSetting('security.loginAttempts')">Save</button>
                            <span class="setting-saved" id="saved-security.loginAttempts">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Lockout Duration (minutes)</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="security.loginLockout" value="<%= config.security.loginLockout / (60 * 1000) %>" data-key="security.loginLockout">
                            <button class="save-btn" onclick="saveSetting('security.loginLockout', null, 60000)">Save</button>
                            <span class="setting-saved" id="saved-security.loginLockout">✓</span>
                        </div>
                    </div>
                </div>

                <!-- Socket -->
                <div class="settings-section">
                    <h3>🔌 Socket.IO</h3>
                    <div class="setting-item">
                        <span class="setting-label">Ping Interval (seconds)</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="socket.pingInterval" value="<%= config.socket.pingInterval / 1000 %>" data-key="socket.pingInterval">
                            <button class="save-btn" onclick="saveSetting('socket.pingInterval', null, 1000)">Save</button>
                            <span class="setting-saved" id="saved-socket.pingInterval">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Ping Timeout (seconds)</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="socket.pingTimeout" value="<%= config.socket.pingTimeout / 1000 %>" data-key="socket.pingTimeout">
                            <button class="save-btn" onclick="saveSetting('socket.pingTimeout', null, 1000)">Save</button>
                            <span class="setting-saved" id="saved-socket.pingTimeout">✓</span>
                        </div>
                    </div>
                </div>

                <!-- Rate Limiting -->
                <div class="settings-section">
                    <h3>⚡ Rate Limiting</h3>
                    <div class="setting-item">
                        <span class="setting-label">Window (seconds)</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="rateLimit.windowMs" value="<%= config.rateLimit.windowMs / 1000 %>" data-key="rateLimit.windowMs">
                            <button class="save-btn" onclick="saveSetting('rateLimit.windowMs', null, 1000)">Save</button>
                            <span class="setting-saved" id="saved-rateLimit.windowMs">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Max Requests</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="rateLimit.maxRequests" value="<%= config.rateLimit.maxRequests %>" data-key="rateLimit.maxRequests">
                            <button class="save-btn" onclick="saveSetting('rateLimit.maxRequests')">Save</button>
                            <span class="setting-saved" id="saved-rateLimit.maxRequests">✓</span>
                        </div>
                    </div>
                </div>

                <!-- Logger -->
                <div class="settings-section">
                    <h3>📝 Logger</h3>
                    <div class="setting-item">
                        <span class="setting-label">Max DB Logs</span>
                        <div class="setting-value">
                            <input type="number" class="setting-input small" id="logger.maxDbLogs" value="<%= config.logger.maxDbLogs %>" data-key="logger.maxDbLogs">
                            <button class="save-btn" onclick="saveSetting('logger.maxDbLogs')">Save</button>
                            <span class="setting-saved" id="saved-logger.maxDbLogs">✓</span>
                        </div>
                    </div>
                    <div class="setting-item">
                        <span class="setting-label">Console Enabled</span>
                        <div class="setting-value">
                            <label class="toggle-switch">
                                <input type="checkbox" id="logger.console.enabled" <%= config.logger.console.enabled ? 'checked' : '' %> onchange="saveSetting('logger.console.enabled', this.checked)">
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="warning-box">
                <p>⚠️ <strong>Note:</strong> Some settings may require a server restart to take effect. Changes are saved to the config file immediately.</p>
            </div>
        </div>
    </main>

    <div id="toast" class="toast"></div>
    <script src="/js/app.js"></script>
</body>
</html>
