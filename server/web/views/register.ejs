<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fason - Register</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-page">
    <div class="login-box">
        <div class="logo">
            <div class="fs-icon">FS</div>
            <h1>Fason</h1>
        </div>

        <% if (typeof error !== 'undefined') { %>
        <div class="alert error">
            <% if (error === '1') { %>Username already exists<% } %>
            <% if (error === '2') { %>Password must be at least 6 characters<% } %>
            <% if (error === '3') { %>Username must be at least 3 characters<% } %>
            <% if (error === '4') { %>Passwords do not match<% } %>
            <% if (error === '5') { %>Registration failed. Please try again.<% } %>
        </div>
        <% } %>

        <% if (typeof success !== 'undefined') { %>
        <div class="alert success">Registration successful! You can now login.</div>
        <% } %>

        <form action="/register" method="POST">
            <div class="input-group">
                <input type="text" name="user" placeholder="Username" required autofocus minlength="3" maxlength="20">
            </div>
            <div class="input-group">
                <input type="password" name="pass" placeholder="Password" required minlength="6">
            </div>
            <div class="input-group">
                <input type="password" name="passConfirm" placeholder="Confirm Password" required>
            </div>
            <button type="submit" class="btn primary full">Create Account</button>
        </form>

        <div class="login-link">
            Already have an account? <a href="/login">Sign In</a>
        </div>
    </div>
</body>
</html>
