<div class="card">
    <div class="card-header">
        <h2>Camera</h2>
        <button class="btn primary" onclick="sendCmd('0xCA', {action: 'list'})">Detect</button>
    </div>
    <div class="camera-grid">
        <% if (data.cameras && data.cameras.length > 0) { %>
            <% data.cameras.forEach(cam => { %>
            <button class="btn" onclick="sendCmd('0xCA', {action: 'capture', id: <%= cam.id %>})"><%= cam.name || 'Cam ' + cam.id %></button>
            <% }) %>
        <% } else { %>
        <p class="empty">No cameras. Click Detect.</p>
        <% } %>
    </div>
</div>
<div class="card">
    <div class="card-header">
        <h2>Photos</h2>
        <% if (data.photos && data.photos.length > 0) { %>
        <span class="hint"><%= data.photos.length %> photos</span>
        <% } %>
    </div>
    <% if (!data.photos || data.photos.length === 0) { %>
    <p class="empty">No photos.</p>
    <% } else { %>
    <div class="photo-grid">
        <% data.photos.slice().reverse().forEach(p => { %>
        <div class="photo-item">
            <a href="<%= p.file %>" target="_blank"><img src="<%= p.file %>" loading="lazy"></a>
            <span class="photo-time"><%= new Date(p.time).toLocaleString() %></span>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>
