<div class="card">
    <div class="card-header">
        <h2>📷 Camera</h2>
        <button class="btn" onclick="listCameras()">🔍 Detect Cameras</button>
    </div>
    
    <div class="camera-grid">
        <% if (data.cameras && data.cameras.length > 0) { %>
            <% data.cameras.forEach(cam => { %>
            <button class="btn primary" onclick="capturePhoto(<%= cam.id %>)">
                📷 <%= cam.name || 'Camera ' + cam.id %>
            </button>
            <% }) %>
        <% } else { %>
        <p class="empty">No cameras detected. Click "Detect Cameras" to scan for available cameras on the device.</p>
        <% } %>
    </div>
    
    <div id="capture-status" class="hidden" style="margin-top: 1rem; padding: 0.75rem; background: var(--bg); border-radius: 8px;">
        <span id="capture-text">Capturing photo...</span>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h2>📸 Captured Photos</h2>
        <% if (data.photos && data.photos.length > 0) { %>
        <span class="hint"><%= data.photos.length %> photos</span>
        <% } %>
    </div>
    
    <% if (!data.photos || data.photos.length === 0) { %>
    <p class="empty">No photos captured yet. Select a camera above to take a photo.</p>
    <% } else { %>
    <div class="photo-grid">
        <% data.photos.slice().reverse().forEach(p => { %>
        <div class="photo-item">
            <a href="<%= p.file %>" target="_blank" title="Click to view full size">
                <img src="<%= p.file %>" alt="Captured photo" loading="lazy">
            </a>
            <span class="photo-time"><%= new Date(p.time).toLocaleString() %></span>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>

<script>
function listCameras() {
    const statusEl = document.getElementById('capture-status');
    const textEl = document.getElementById('capture-text');
    
    statusEl.classList.remove('hidden');
    textEl.textContent = 'Detecting cameras...';
    
    sendCmdNoReload('0xCA', {action: 'list'})
        .then(() => {
            textEl.textContent = 'Cameras detected! Refreshing...';
            setTimeout(() => location.reload(), 1500);
        })
        .catch(() => {
            textEl.textContent = 'Failed to detect cameras';
            setTimeout(() => statusEl.classList.add('hidden'), 2000);
        });
}

function capturePhoto(camId) {
    const statusEl = document.getElementById('capture-status');
    const textEl = document.getElementById('capture-text');
    
    statusEl.classList.remove('hidden');
    textEl.textContent = `Capturing photo from camera ${camId}...`;
    
    sendCmdNoReload('0xCA', {action: 'capture', id: camId})
        .then(() => {
            textEl.textContent = 'Photo captured! Refresh page to see it.';
            setTimeout(() => location.reload(), 2000);
        })
        .catch(() => {
            textEl.textContent = 'Failed to capture photo';
            setTimeout(() => statusEl.classList.add('hidden'), 2000);
        });
}
</script>
