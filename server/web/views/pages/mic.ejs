<div class="card">
    <h2>Mic Recording</h2>
    <p class="hint">Record audio from device. The progress shows actual recording time.</p>
    <div class="form-row" style="margin-top: 1rem;">
        <select id="mic-duration">
            <option value="10">10 seconds</option>
            <option value="30">30 seconds</option>
            <option value="60" selected>1 minute</option>
            <option value="120">2 minutes</option>
            <option value="300">5 minutes</option>
            <option value="600">10 minutes</option>
        </select>
        <button class="btn primary" id="recordBtn" onclick="recordMic()">🎤 Record</button>
    </div>
    <div id="recording-status" class="hidden recording-status">
        <div class="status-row">
            <span class="status-dot online" style="animation: pulse 1s infinite;"></span>
            <span id="status-text">Recording...</span>
        </div>
        <div class="progress-bar" style="margin-top: 0.5rem;">
            <div class="progress-fill" id="record-progress" style="width: 0%;"></div>
        </div>
    </div>
</div>
<div class="card">
    <div class="card-header">
        <h2>Recordings</h2>
        <div style="display:flex;align-items:center;gap:0.5rem;">
            <% if (data.list && data.list.length > 0) { %>
            <span class="hint"><%= data.list.length %> recordings</span>
            <% } %>
            <button class="btn" onclick="location.reload()"></button>
        </div>
    </div>
    <% if (!data.list || data.list.length === 0) { %>
    <p class="empty">No recordings.</p>
    <% } else { %>
    <div class="recordings-list">
        <% data.list.slice().reverse().forEach(r => { %>
        <div class="recording-item">
            <audio controls src="<%= r.file %>" preload="metadata"></audio>
            <div class="recording-info">
                <span class="recording-time"><%= new Date(r.time).toLocaleString() %></span>
                <a href="<%= r.file %>" download class="btn small">Download</a>
            </div>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>
