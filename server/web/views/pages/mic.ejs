<div class="card">
    <h2>🎤 Microphone Recording</h2>
    <p class="hint">Record audio from the device microphone. Audio files will appear in the Downloads page after recording completes.</p>
    
    <div class="form-row" style="margin-top: 1rem;">
        <select id="mic-duration">
            <option value="10">10 seconds</option>
            <option value="30">30 seconds</option>
            <option value="60" selected>1 minute</option>
            <option value="120">2 minutes</option>
            <option value="300">5 minutes</option>
            <option value="600">10 minutes</option>
        </select>
        <button class="btn primary" id="recordBtn" onclick="recordMic()">🎤 Start Recording</button>
    </div>
    
    <div id="recording-status" class="hidden" style="margin-top: 1rem; padding: 1rem; background: var(--bg); border-radius: 8px;">
        <div style="display: flex; align-items: center; gap: 0.5rem;">
            <span class="status-dot online" style="animation: pulse 1s infinite;"></span>
            <span id="status-text">Recording...</span>
        </div>
        <div class="progress-bar" style="margin-top: 0.5rem;">
            <div class="progress-fill" id="record-progress" style="width: 0%; background: var(--error);"></div>
        </div>
    </div>
</div>

<style>
@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
}
</style>

<script>
function recordMic() {
    const sec = parseInt(document.getElementById('mic-duration').value);
    const btn = document.getElementById('recordBtn');
    const status = document.getElementById('recording-status');
    const progress = document.getElementById('record-progress');
    const statusText = document.getElementById('status-text');
    
    // Disable button and show status
    btn.disabled = true;
    btn.textContent = '⏳ Recording...';
    status.classList.remove('hidden');
    statusText.textContent = `Recording ${sec} seconds of audio...`;
    
    // Animate progress
    let elapsed = 0;
    const interval = setInterval(() => {
        elapsed += 0.1;
        const pct = Math.min(100, (elapsed / sec) * 100);
        progress.style.width = pct + '%';
        
        if (elapsed >= sec) {
            clearInterval(interval);
        }
    }, 100);
    
    // Send command
    sendCmdNoReload('0xMI', {sec: sec})
        .then(() => {
            statusText.textContent = 'Recording complete! Check Downloads page.';
            progress.style.width = '100%';
            progress.style.background = 'var(--success)';
        })
        .catch(() => {
            statusText.textContent = 'Recording failed';
            progress.style.background = 'var(--error)';
        })
        .finally(() => {
            setTimeout(() => {
                btn.disabled = false;
                btn.textContent = '🎤 Start Recording';
                status.classList.add('hidden');
                progress.style.width = '0%';
                progress.style.background = 'var(--error)';
            }, 3000);
        });
}
</script>
