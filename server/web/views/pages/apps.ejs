<div class="card">
    <div class="card-header">
        <h2>Apps</h2>
        <div class="btn-group">
            <button class="btn primary" onclick="sendCmd('0xIN', {sys: false})">User</button>
            <button class="btn" onclick="sendCmd('0xIN', {sys: true})">All</button>
        </div>
    </div>
    <% if (!data.list || data.list.length === 0) { %>
    <p class="empty">No apps.</p>
    <% } else { %>
    <p class="hint"><%= data.list.length %> apps</p>
    <div class="app-grid">
        <% data.list.forEach(app => { %>
        <div class="app-item">
            <div class="app-name"><%= app.appName %></div>
            <div class="app-pkg"><code><%= app.packageName %></code></div>
            <div class="app-version">v<%= app.versionName %> <% if (app.isSystem) { %><span class="badge">Sys</span><% } %></div>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>
