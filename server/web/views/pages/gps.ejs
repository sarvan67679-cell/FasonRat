<div class="card">
    <div class="card-header">
        <h2>📍 Location Tracking</h2>
        <div class="btn-group">
            <button class="btn primary" onclick="sendCmd('0xLO')">📍 Get Location Now</button>
            <select id="gps-interval" onchange="setGpsInterval(this.value)">
                <option value="0" <%= data.interval == 0 ? 'selected' : '' %>>Auto: Off</option>
                <option value="10" <%= data.interval == 10 ? 'selected' : '' %>>Every 10s</option>
                <option value="30" <%= data.interval == 30 ? 'selected' : '' %>>Every 30s</option>
                <option value="60" <%= data.interval == 60 ? 'selected' : '' %>>Every 1m</option>
                <option value="300" <%= data.interval == 300 ? 'selected' : '' %>>Every 5m</option>
                <option value="600" <%= data.interval == 600 ? 'selected' : '' %>>Every 10m</option>
            </select>
        </div>
    </div>
    
    <div id="map" style="height: 400px; border-radius: 8px; background: var(--card-alt); margin-top: 1rem;"></div>
    
    <% if (!data.list || data.list.length === 0) { %>
    <p class="hint" style="margin-top: 1rem;">No location data yet. Click "Get Location Now" or enable auto-tracking.</p>
    <% } %>
</div>

<div class="card">
    <div class="card-header">
        <h2>📋 Location History</h2>
        <% if (data.list && data.list.length > 0) { %>
        <span class="hint"><%= data.list.length %> locations recorded</span>
        <% } %>
    </div>
    
    <% if (!data.list || data.list.length === 0) { %>
    <p class="empty">No location data available.</p>
    <% } else { %>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Latitude</th>
                    <th>Longitude</th>
                    <th>Accuracy</th>
                    <th>Time</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <% data.list.slice(-30).reverse().forEach((loc, i) => { %>
                <tr>
                    <td><%= i + 1 %></td>
                    <td><code><%= loc.latitude?.toFixed(6) %></code></td>
                    <td><code><%= loc.longitude?.toFixed(6) %></code></td>
                    <td><%= loc.accuracy ? loc.accuracy.toFixed(0) + 'm' : '—' %></td>
                    <td><%= new Date(loc.time).toLocaleString() %></td>
                    <td>
                        <button class="btn small" onclick="centerMap(<%= loc.latitude %>, <%= loc.longitude %>)">View</button>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>

<script>
let mapInstance = null;
let markers = [];

document.addEventListener('DOMContentLoaded', function() {
    const locations = <%- JSON.stringify(data.list || []) %>;
    
    // Initialize map
    mapInstance = L.map('map').setView([0, 0], 2);
    
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
    }).addTo(mapInstance);
    
    // Add markers for all locations
    if (locations.length > 0) {
        const last = locations[locations.length - 1];
        mapInstance.setView([last.latitude, last.longitude], 15);
        
        locations.forEach((loc, i) => {
            const marker = L.marker([loc.latitude, loc.longitude])
                .addTo(mapInstance)
                .bindPopup(`<b>#${i + 1}</b><br>${new Date(loc.time).toLocaleString()}<br>Accuracy: ${loc.accuracy ? loc.accuracy.toFixed(0) + 'm' : 'N/A'}`);
            markers.push(marker);
        });
        
        // Draw path line
        if (locations.length > 1) {
            const line = locations.map(l => [l.latitude, l.longitude]);
            L.polyline(line, {color: '#3b82f6', weight: 3, opacity: 0.7}).addTo(mapInstance);
        }
    }
});

function centerMap(lat, lng) {
    if (mapInstance) {
        mapInstance.setView([lat, lng], 16);
    }
}

function setGpsInterval(val) {
    const interval = parseInt(val);
    
    fetch(`/gps/${DEVICE_ID}/${interval}`, {method: 'POST'})
        .then(r => r.json())
        .then(d => {
            if (d.success) {
                toast(interval > 0 ? `GPS polling enabled (${interval}s)` : 'GPS polling disabled', 'success');
            } else {
                toast('Failed to update GPS settings', 'error');
            }
        })
        .catch(() => {
            toast('Request failed', 'error');
        });
}
</script>
