<div class="card">
    <div class="card-header">
        <h2>📍 Location</h2>
        <div class="btn-group">
            <button class="btn primary" onclick="sendCmd('0xLO')">📍 Get Now</button>
            <select id="gps-interval" onchange="setGpsInterval(this.value)">
                <option value="0" <%= data.interval == 0 ? 'selected' : '' %>>Off</option>
                <option value="10" <%= data.interval == 10 ? 'selected' : '' %>>10s</option>
                <option value="30" <%= data.interval == 30 ? 'selected' : '' %>>30s</option>
                <option value="60" <%= data.interval == 60 ? 'selected' : '' %>>1m</option>
                <option value="300" <%= data.interval == 300 ? 'selected' : '' %>>5m</option>
                <option value="600" <%= data.interval == 600 ? 'selected' : '' %>>10m</option>
            </select>
        </div>
    </div>
    <div id="map" style="height: 400px; border-radius: 8px; background: var(--card-alt); margin-top: 1rem;"></div>
</div>
<div class="card">
    <div class="card-header">
        <h2>📋 History</h2>
        <% if (data.list && data.list.length > 0) { %>
        <span class="hint"><%= data.list.length %> points</span>
        <% } %>
    </div>
    <% if (!data.list || data.list.length === 0) { %>
    <p class="empty">No location data.</p>
    <% } else { %>
    <div class="table-wrap">
        <table>
            <thead><tr><th>#</th><th>Lat</th><th>Lng</th><th>Acc</th><th>Time</th><th></th></tr></thead>
            <tbody>
                <% data.list.slice(-30).reverse().forEach((loc, i) => { %>
                <tr>
                    <td><%= i + 1 %></td>
                    <td><code><%= loc.latitude?.toFixed(6) %></code></td>
                    <td><code><%= loc.longitude?.toFixed(6) %></code></td>
                    <td><%= loc.accuracy ? loc.accuracy.toFixed(0) + 'm' : '—' %></td>
                    <td><%= new Date(loc.time).toLocaleString() %></td>
                    <td><button class="btn small" onclick="centerMap(<%= loc.latitude %>, <%= loc.longitude %>)">View</button></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
    initMap(<%- JSON.stringify(data.list || []) %>);
});
</script>
