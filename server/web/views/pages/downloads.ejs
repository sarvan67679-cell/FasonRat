<div class="card">
    <div class="card-header">
        <h2>Downloads</h2>
        <button class="btn" onclick="location.reload()">Refresh</button>
    </div>
    <% if (!data.list || data.list.length === 0) { %>
    <p class="empty">No files.</p>
    <% } else { %>
    <p class="hint"><%= data.list.length %> files</p>
    <div class="table-wrap">
        <table>
            <thead><tr><th>Name</th><th>Size</th><th>Time</th><th></th></tr></thead>
            <tbody>
                <% data.list.slice().reverse().forEach(d => { %>
                <tr>
                    <td><%= d.name %></td>
                    <td><%= d.size ? (d.size / 1024).toFixed(1) + ' KB' : '-' %></td>
                    <td><%= new Date(d.time).toLocaleString() %></td>
                    <td><a href="<%= d.file %>" class="btn small" download>Download</a></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
    <% } %>
</div>
