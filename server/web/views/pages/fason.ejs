<div class="card">
    <div class="card-header">
        <h2>Fason Manager</h2>
        <button class="btn" onclick="refreshFasonStatus()">Refresh Status</button>
    </div>
    <p class="hint">Manage the Fason app visibility on this device.</p>
    <div class="fason-manager">
        <div class="fason-status-card">
            <div class="fason-status-icon" id="fasonStatusIcon"><%= data.hidden ? 'X' : 'OK' %></div>
            <div class="fason-status-info">
                <h3>Fason App</h3>
                <p id="fasonStatusText" class="status-text <%= data.hidden ? 'hidden' : 'visible' %>">
                    <%= data.hidden ? 'Hidden from launcher' : 'Visible in launcher' %>
                </p>
            </div>
        </div>
        <div class="fason-actions">
            <button class="btn" id="fasonHideBtn" onclick="hideFasonApp()" <%= data.hidden ? 'style="display:none;"' : '' %>>Hide from Launcher</button>
            <button class="btn primary" id="fasonShowBtn" onclick="showFasonApp()" <%= !data.hidden ? 'style="display:none;"' : '' %>>Show in Launcher</button>
        </div>
        <div class="fason-info">
            <p><strong>Hide:</strong> Removes the Fason app icon from the launcher. The app continues running in background.</p>
            <p><strong>Show:</strong> Restores the Fason app icon in the launcher.</p>
        </div>
    </div>
</div>
