<div class="card">
    <div class="card-header">
        <h2>Notifications</h2>
        <span class="hint">Notifications are captured automatically when enabled on device.</span>
    </div>
    
    <% if (!data.list || data.list.length === 0) { %>
    <p class="empty">No notifications captured yet.</p>
    <% } else { %>
    <div class="notif-list">
        <% data.list.slice().reverse().slice(0, 50).forEach(n => { %>
        <div class="notif-item">
            <div class="notif-header">
                <span class="notif-app"><%= n.appName %></span>
                <span class="notif-time"><%= new Date(n.time).toLocaleString() %></span>
            </div>
            <% if (n.title) { %><div class="notif-title"><%= n.title %></div><% } %>
            <% if (n.content) { %><div class="notif-content"><%= n.content %></div><% } %>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>
