<div class="card">
    <div class="card-header">
        <h2>Permissions</h2>
        <button class="btn" onclick="sendCmd('0xPM')">Refresh</button>
    </div>
    <% if (!data.list || data.list.length === 0) { %>
    <p class="empty">No permissions.</p>
    <% } else { %>
    <p class="hint"><%= data.list.length %> granted</p>
    <div class="perm-grid">
        <% data.list.forEach(p => { 
            const name = typeof p === 'string' ? p.split('.').pop() : (p.permission || p.name || 'unknown').split('.').pop();
            const allowed = typeof p === 'object' ? p.allowed : true;
        %>
        <div class="perm-item">
            <span class="perm-icon <%= allowed ? 'success' : 'warning' %>"><%= allowed ? 'OK' : '?' %></span>
            <span><%= name %></span>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>
