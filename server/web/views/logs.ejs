<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>System Logs - Fason</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 1rem;
            margin-bottom: 1.5rem;
        }
        .stat-card {
            background: var(--bg);
            border-radius: 8px;
            padding: 1rem;
            text-align: center;
        }
        .stat-value {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--primary);
        }
        .stat-label {
            font-size: 0.75rem;
            color: var(--muted);
            margin-top: 0.25rem;
        }
        .stat-card.error .stat-value { color: var(--error); }
        .stat-card.warning .stat-value { color: var(--warning); }
        .stat-card.success .stat-value { color: var(--success); }
        
        .filter-bar {
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
            margin-bottom: 1rem;
        }
        .filter-bar select, .filter-bar input {
            background: var(--bg);
            border: 1px solid var(--border);
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            color: var(--text);
            font-size: 0.9rem;
        }
        .filter-bar input { flex: 1; min-width: 200px; }
        
        .log-row { transition: background 0.2s; }
        .log-row:hover { background: rgba(255,255,255,0.02); }
        
        .log-row.log-error { border-left: 3px solid var(--error); }
        .log-row.log-warning { border-left: 3px solid var(--warning); }
        .log-row.log-success { border-left: 3px solid var(--success); }
        .log-row.log-connection { border-left: 3px solid #8b5cf6; }
        .log-row.log-disconnection { border-left: 3px solid #f97316; }
        .log-row.log-command { border-left: 3px solid #06b6d4; }
        .log-row.log-data { border-left: 3px solid #10b981; }
        .log-row.log-build { border-left: 3px solid #a855f7; }
        .log-row.log-auth { border-left: 3px solid #ec4899; }
        .log-row.log-file { border-left: 3px solid #6366f1; }
        
        .type-badge {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
        }
        .type-badge.info { background: rgba(59, 130, 246, 0.2); color: #3b82f6; }
        .type-badge.success { background: rgba(34, 197, 94, 0.2); color: #22c55e; }
        .type-badge.error { background: rgba(239, 68, 68, 0.2); color: #ef4444; }
        .type-badge.warning { background: rgba(245, 158, 11, 0.2); color: #f59e0b; }
        .type-badge.connection { background: rgba(139, 92, 246, 0.2); color: #8b5cf6; }
        .type-badge.disconnection { background: rgba(249, 115, 22, 0.2); color: #f97316; }
        .type-badge.command { background: rgba(6, 182, 212, 0.2); color: #06b6d4; }
        .type-badge.data { background: rgba(16, 185, 129, 0.2); color: #10b981; }
        .type-badge.build { background: rgba(168, 85, 247, 0.2); color: #a855f7; }
        .type-badge.auth { background: rgba(236, 72, 153, 0.2); color: #ec4899; }
        .type-badge.file { background: rgba(99, 102, 241, 0.2); color: #6366f1; }
        
        .category-tag {
            font-size: 10px;
            padding: 1px 6px;
            border-radius: 3px;
            background: var(--card-alt);
            color: var(--muted);
            margin-left: 6px;
        }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="brand"><span class="fs-icon-sm">FS</span> Fason</a>
        <div class="nav-links">
            <a href="/">Dashboard</a>
            <a href="/builder">Builder</a>
            <a href="/logs" class="active">Logs</a>
            <a href="/logout">Logout</a>
        </div>
    </nav>

    <main class="container">
        <!-- Statistics -->
        <% if (typeof stats !== 'undefined') { %>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value"><%= stats.total || 0 %></div>
                <div class="stat-label">Total Logs</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%= stats.today || 0 %></div>
                <div class="stat-label">Today</div>
            </div>
            <div class="stat-card">
                <div class="stat-value"><%= stats.lastHour || 0 %></div>
                <div class="stat-label">Last Hour</div>
            </div>
            <div class="stat-card error">
                <div class="stat-value"><%= stats.errors || 0 %></div>
                <div class="stat-label">Errors</div>
            </div>
            <div class="stat-card warning">
                <div class="stat-value"><%= stats.warnings || 0 %></div>
                <div class="stat-label">Warnings</div>
            </div>
        </div>
        <% } %>
        
        <div class="card logs-card">
            <div class="card-header">
                <h2>System Logs</h2>
                <div class="btn-group">
                    <button id="refreshBtn" class="btn">↻ Refresh</button>
                    <button id="clearBtn" class="btn danger">✕ Clear All</button>
                </div>
            </div>
            
            <!-- Filter Bar -->
            <form class="filter-bar" method="GET" action="/logs">
                <select name="type">
                    <option value="">All Types</option>
                    <option value="info" <%= filters?.type === 'info' ? 'selected' : '' %>>Info</option>
                    <option value="success" <%= filters?.type === 'success' ? 'selected' : '' %>>Success</option>
                    <option value="error" <%= filters?.type === 'error' ? 'selected' : '' %>>Error</option>
                    <option value="warning" <%= filters?.type === 'warning' ? 'selected' : '' %>>Warning</option>
                    <option value="connection" <%= filters?.type === 'connection' ? 'selected' : '' %>>Connection</option>
                    <option value="disconnection" <%= filters?.type === 'disconnection' ? 'selected' : '' %>>Disconnection</option>
                    <option value="command" <%= filters?.type === 'command' ? 'selected' : '' %>>Command</option>
                    <option value="data" <%= filters?.type === 'data' ? 'selected' : '' %>>Data</option>
                    <option value="build" <%= filters?.type === 'build' ? 'selected' : '' %>>Build</option>
                    <option value="auth" <%= filters?.type === 'auth' ? 'selected' : '' %>>Auth</option>
                </select>
                <select name="category">
                    <option value="">All Categories</option>
                    <option value="system" <%= filters?.category === 'system' ? 'selected' : '' %>>System</option>
                    <option value="client" <%= filters?.category === 'client' ? 'selected' : '' %>>Client</option>
                    <option value="build" <%= filters?.category === 'build' ? 'selected' : '' %>>Build</option>
                    <option value="auth" <%= filters?.category === 'auth' ? 'selected' : '' %>>Auth</option>
                    <option value="data" <%= filters?.category === 'data' ? 'selected' : '' %>>Data</option>
                    <option value="file" <%= filters?.category === 'file' ? 'selected' : '' %>>File</option>
                    <option value="error" <%= filters?.category === 'error' ? 'selected' : '' %>>Error</option>
                </select>
                <input type="text" name="search" placeholder="Search logs..." value="<%= filters?.search || '' %>">
                <button type="submit" class="btn primary">Filter</button>
                <a href="/logs" class="btn">Reset</a>
            </form>
            
            <div class="logs-container">
                <% if (logs.length === 0) { %>
                    <div class="empty">
                        <p>No logs found</p>
                    </div>
                <% } else { %>
                    <table class="logs-table">
                        <thead>
                            <tr>
                                <th width="170">Time</th>
                                <th width="130">Type</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% logs.forEach(log => { %>
                                <tr class="log-row log-<%= log.type.toLowerCase() %>">
                                    <td class="time"><%= new Date(log.time).toLocaleString() %></td>
                                    <td>
                                        <span class="type-badge <%= log.type.toLowerCase() %>"><%= log.type %></span>
                                        <% if (log.category) { %>
                                            <span class="category-tag"><%= log.category %></span>
                                        <% } %>
                                    </td>
                                    <td class="message"><%= log.message %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } %>
            </div>
        </div>
    </main>

    <div id="toast" class="toast"></div>
    <script>
        document.getElementById('refreshBtn').onclick = () => location.reload();
        
        document.getElementById('clearBtn').onclick = async () => {
            if (!confirm('Are you sure you want to clear all logs? This cannot be undone.')) return;
            
            try {
                const res = await fetch('/logs/clear', { method: 'POST' });
                const data = await res.json();
                if (data.success) {
                    toast('Logs cleared', 'success');
                    setTimeout(() => location.reload(), 500);
                } else {
                    toast(data.error || 'Failed to clear logs', 'error');
                }
            } catch (e) {
                toast('Request failed', 'error');
            }
        };
        
        function toast(msg, type = 'info') {
            const t = document.getElementById('toast');
            if (!t) return;
            t.textContent = msg;
            t.className = 'toast show ' + type;
            setTimeout(() => { t.className = 'toast'; }, 2500);
        }
    </script>
</body>
</html>
