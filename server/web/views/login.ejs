<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fason - Login</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="login-page">
    <div class="login-box">
        <div class="logo">
            <div class="fs-icon">FS</div>
            <h1>Fason</h1>
        </div>

        <% if (typeof error !== 'undefined') { %>
        <div class="alert error">Invalid username or password</div>
        <% } %>

        <% if (typeof locked !== 'undefined') { %>
        <div class="alert error">Too many failed attempts. Please try again later.</div>
        <% } %>

        <% if (typeof expired !== 'undefined') { %>
        <div class="alert warning">Your session has expired. Please login again.</div>
        <% } %>

        <% if (typeof registered !== 'undefined') { %>
        <div class="alert success">Registration successful! You can now login.</div>
        <% } %>

        <form action="/login" method="POST">
            <div class="input-group">
                <input type="text" name="user" placeholder="Username" required autofocus>
            </div>
            <div class="input-group">
                <input type="password" name="pass" placeholder="Password" required>
            </div>
            <button type="submit" class="btn primary full">Sign In</button>
        </form>

        <div class="login-link">
            Don't have an account? <a href="/register">Create Account</a>
        </div>
    </div>
</body>
</html>
